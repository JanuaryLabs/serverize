---
import '@/styles/globals.css';
import { Content as FaqContent } from '../lib/sections/faq.md';
import { Content as HowItWorksContent } from '../lib/sections/how-it-works.md';
import { Content as IndexContent } from '../lib/sections/index.md';
import { Content as MotivationContent } from '../lib/sections/motivation.md';
import { Content as OptimisationContent } from '../lib/sections/optimisation.md';
import { Content as StaticWebsiteContent } from '../lib/sections/static-website.md';
import { Content as TheConversationContent } from '../lib/sections/the-conversation.md';
import Integrations from '../lib/sections/integrations.astro';
import '@fontsource/roboto';
import '@fontsource/fira-code';
import '@fontsource/crimson-text';
import MDXCodeBox from '../lib/code/code';
import Email from '../lib/email';
import Background from '../lib/background';
import Try from '../lib/try';
import { TextGenerateEffect } from '../lib/text-generate-effect';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>January - Serverize</title>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css?family=Italiana&subset=latin"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/9.10.0/styles/github.min.css"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css?family=Italiana&subset=latin"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/9.10.0/styles/github.min.css"
    />
    <meta
      name="viewport"
      content="user-scalable=no, width=device-width, initial-scale=1.0, maximum-scale=1.0"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex flex-col h-full">
    <Background>
      <div class="max-w-4xl w-full mx-auto">
        <!-- <navbar class="mt-12 block mb-20">
        <div class="font-mono text-lg font-bold">
          Serveri<span style="transform: rotateY(180deg);" class="inline-block"
            >z</span
          >e
        </div>
      </navbar> -->
        <div class="w-full flex items-center justify-center flex-col">
          <!-- <div class="font-mono lowercase text-9xl leading-normal md:text-[150px]">
        Serveri<span style="transform: rotateY(180deg);" class="inline-block"
          >z</span
        >e
      </div> -->
          <!-- <div class="mb-8">Stop waiting for deployments.</div>
       -->
          <!-- <h1 class="text-5xl">
          Transform your local setup into an instantly accessible cloud
          environment with automatic updates as you code
        </h1> -->
          <!-- <h1 class="text-6xl font-medium" style="font-family: 'Crimson Text';">
          Turn your development setup to an instantly accessible cloud
          environment
        </h1> -->
          <h1 style="font-family: 'Crimson Text';">
            <TextGenerateEffect
              client:idle
              filter={false}
              duration={1.5}
              words={'Turn your development setup into an accessible cloud environment.'}
            />
          </h1>
          <h2 class="md:text-lg mt-8 mb-12">
            Serverize optimizes your development workflow by placing your
            development setup in the cloud, allowing for quick feedback,
            immediate testing, easy sharing, and smooth team collaboration.
            <strong>Deployment happens, but without the usual wait.</strong>

            <!-- Serverize optimizes your development workflow by
          deploying your setup to the cloud in real time, allowing
          UI developers, stakeholders, and clients to see updates quickly as you
          make changes. -->
          </h2>
          <Try client:idle />
          <div class="italic text-sm mt-4 font-semibold">
            This website is being Serverized
          </div>
          <!-- <p>
          Serverize your static website, API project, or full-stack application
          - streamline development for any type of project.
        </p> -->
        </div>
        <!-- <div class="mt-6 w-6/12"><Email /></div> -->
      </div>
    </Background>
    <div class="prose min-w-full">
     <div class="md:px-20 px-8">
        <Integrations />
      </div>
      <section class="md:px-24 px-8 py-20">
        <div class="content">
          <MotivationContent />
        </div>
      </section>
      <section class="md:px-24 px-8 py-20">
        <div class="content">
          <HowItWorksContent />
        </div>
      </section>
      <section class="md:px-24 px-8 py-20">
        <div class="content">
          <OptimisationContent />
        </div>
      </section>

      <section class="md:px-24 px-8 py-20">
        <div class="content">
          <TheConversationContent />
        </div>
      </section>
      <section class="md:px-24 px-8 py-20">
        <div class="content">
          <StaticWebsiteContent />
        </div>
      </section>
      <!-- <section class="md:px-24 px-8 py-20">
        <div class="content">
          <FaqContent />
        </div>
      </section> -->
    </div>
